# Server
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=8h

# CORS — frontend origin
CLIENT_ORIGIN=http://localhost:5173

# Database — MongoDB Atlas
# Get this from Atlas → Connect → Drivers. Leave blank to run purely in-memory.
# Example: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=vendorbridge

# AI — set ONE of these to enable AI features (Claude preferred).
# Without a key the AI endpoints still work via a local heuristic fallback.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional model override (defaults: claude-3-5-sonnet-latest / gpt-4o-mini)
AI_MODEL=
